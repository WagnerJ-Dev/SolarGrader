# Copy this file to .env and fill in real values. .env is gitignored — never commit it.
# Load in Python with: from dotenv import load_dotenv; load_dotenv()
# Read with: os.environ["NREL_API_KEY"]  (raises if missing — fail loud, never default a secret)

# NREL NSRDB / Developer Network — free key from https://developer.nrel.gov/signup/
# Needed for solar irradiance lookups (NSRDB, PVWatts).
NREL_API_KEY=

# Optional contact email some NREL endpoints request alongside the key.
NREL_API_EMAIL=
